# =============================================================================
# ATLAS Platform - Environment Configuration
# =============================================================================
# Copy this file to .env and configure with your values
# NEVER commit .env to version control

# =============================================================================
# Application
# =============================================================================
APP_NAME=ATLAS Platform
APP_VERSION=1.0.1
APP_DESCRIPTION=AI-Powered Business Intelligence Operating System
DEBUG=true
ENVIRONMENT=development

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=1

# API
API_V1_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]

# =============================================================================
# Security
# =============================================================================
# Generate a secure key: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# Database - PostgreSQL
# =============================================================================
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=atlas
DATABASE_USER=atlas
DATABASE_PASSWORD=your-db-password
DATABASE_URL=postgresql+asyncpg://${DATABASE_USER}:${DATABASE_PASSWORD}@${DATABASE_HOST}:${DATABASE_PORT}/${DATABASE_NAME}
DATABASE_URL_SYNC=postgresql://${DATABASE_USER}:${DATABASE_PASSWORD}@${DATABASE_HOST}:${DATABASE_PORT}/${DATABASE_NAME}

# =============================================================================
# Redis Cache
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/${REDIS_DB}

# =============================================================================
# AI Providers
# =============================================================================
# OpenAI
OPENAI_API_KEY=your-openai-api-key
OPENAI_ORGANIZATION=
OPENAI_PROJECT=
OPENAI_MAX_RETRIES=3

# Google Gemini
GOOGLE_GEMINI_KEY=your-google-gemini-key
GOOGLE_GEMINI_MODEL=gemini-pro

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-3-opus-20240229

# DeepSeek
DEEPSEEK_API_KEY=your-deepseek-api-key

# Mistral
MISTRAL_API_KEY=your-mistral-api-key

# OpenRouter
OPENROUTER_API_KEY=your-openrouter-api-key

# Groq
GROQ_API_KEY=your-groq-api-key

# =============================================================================
# External Services - Search
# =============================================================================
SEARCH_ENGINE_API_KEY=your-search-api-key
SEARCH_TRENDS_API_KEY=your-trends-api-key
KEYWORD_INTELLIGENCE_API_KEY=your-keyword-api-key

# =============================================================================
# Connector Framework - News Providers
# =============================================================================

# Google News (via SerpAPI)
GOOGLE_NEWS_API_KEY=your-serpapi-key
GOOGLE_NEWS_BASE_URL=https://serpapi.com
GOOGLE_NEWS_TIMEOUT=30
GOOGLE_NEWS_MAX_RETRIES=3
GOOGLE_NEWS_RATE_LIMIT_PER_MINUTE=60
GOOGLE_NEWS_RATE_LIMIT_PER_DAY=1000

# NewsAPI
NEWS_API_API_KEY=your-newsapi-key
NEWS_API_BASE_URL=https://newsapi.org/v2
NEWS_API_TIMEOUT=30
NEWS_API_MAX_RETRIES=3
NEWS_API_RATE_LIMIT_PER_MINUTE=100
NEWS_API_RATE_LIMIT_PER_DAY=500

# GDELT (free, no API key required)
GDELT_BASE_URL=https://api.gdeltproject.org/api/v2
GDELT_TIMEOUT=30
GDELT_MAX_RETRIES=3
GDELT_RATE_LIMIT_PER_MINUTE=60
GDELT_RATE_LIMIT_PER_DAY=10000

# Tavily AI Search
TAVILY_API_KEY=your-tavily-key
TAVILY_BASE_URL=https://api.tavily.com
TAVILY_TIMEOUT=30
TAVILY_MAX_RETRIES=3
TAVILY_RATE_LIMIT_PER_MINUTE=60
TAVILY_RATE_LIMIT_PER_DAY=1000

# SerpAPI (general search)
SERP_API_KEY=your-serpapi-key
SERP_BASE_URL=https://serpapi.com
SERP_TIMEOUT=30
SERP_MAX_RETRIES=3
SERP_RATE_LIMIT_PER_MINUTE=50
SERP_RATE_LIMIT_PER_DAY=500

# =============================================================================
# Connector Framework - Financial Providers
# =============================================================================

# Alpha Vantage
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-key
ALPHA_VANTAGE_BASE_URL=https://www.alphavantage.co/query
ALPHA_VANTAGE_TIMEOUT=30
ALPHA_VANTAGE_MAX_RETRIES=3
ALPHA_VANTAGE_RATE_LIMIT_PER_MINUTE=5
ALPHA_VANTAGE_RATE_LIMIT_PER_DAY=500

# Polygon.io
POLYGON_API_KEY=your-polygon-key
POLYGON_BASE_URL=https://api.polygon.io/v2
POLYGON_TIMEOUT=30
POLYGON_MAX_RETRIES=3
POLYGON_RATE_LIMIT_PER_MINUTE=100
POLYGON_RATE_LIMIT_PER_DAY=10000

# Finnhub
FINNHUB_API_KEY=your-finnhub-key
FINNHUB_BASE_URL=https://finnhub.io/api/v1
FINNHUB_TIMEOUT=30
FINNHUB_MAX_RETRIES=3
FINNHUB_RATE_LIMIT_PER_MINUTE=60
FINNHUB_RATE_LIMIT_PER_DAY=5000

# CoinGecko (free tier, no API key required)
COINGECKO_API_KEY=
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
COINGECKO_TIMEOUT=30
COINGECKO_MAX_RETRIES=3
COINGECKO_RATE_LIMIT_PER_MINUTE=50
COINGECKO_RATE_LIMIT_PER_DAY=10000

# FRED (Federal Reserve Economic Data)
FRED_API_KEY=your-fred-key
FRED_BASE_URL=https://api.stlouisfed.org/fred
FRED_TIMEOUT=30
FRED_MAX_RETRIES=3
FRED_RATE_LIMIT_PER_MINUTE=120
FRED_RATE_LIMIT_PER_DAY=10000

# =============================================================================
# Connector Framework - Government & Legal Providers
# =============================================================================

# SEC EDGAR (free, no API key required)
SEC_BASE_URL=https://data.sec.gov
SEC_TIMEOUT=30
SEC_MAX_RETRIES=3
SEC_RATE_LIMIT_PER_MINUTE=10
SEC_RATE_LIMIT_PER_DAY=1000

# USPTO (US Patent and Trademark Office)
USPTO_API_KEY=your-uspto-key
USPTO_BASE_URL=https://developer.uspto.gov/api/v1
USPTO_TIMEOUT=30
USPTO_MAX_RETRIES=3
USPTO_RATE_LIMIT_PER_MINUTE=50
USPTO_RATE_LIMIT_PER_DAY=1000

# OpenCorporates
OPENCORPORATES_API_TOKEN=your-opencorporates-token
OPENCORPORATES_BASE_URL=https://api.opencorporates.com/v0.4
OPENCORPORATES_TIMEOUT=30
OPENCORPORATES_MAX_RETRIES=3
OPENCORPORATES_RATE_LIMIT_PER_MINUTE=60
OPENCORPORATES_RATE_LIMIT_PER_DAY=5000

# =============================================================================
# External Services - News (Legacy)
# =============================================================================
GLOBAL_NEWS_API_KEY=your-global-news-api-key
FINANCIAL_NEWS_API_KEY=your-financial-news-api-key
TECHNOLOGY_NEWS_API_KEY=your-tech-news-api-key
BUSINESS_NEWS_API_KEY=your-business-news-api-key
REGIONAL_NEWS_API_KEY=your-regional-news-api-key
OPEN_NEWS_API_KEY=your-open-news-api-key

# =============================================================================
# External Services - Financial Data (Legacy)
# =============================================================================
STOCK_MARKETS_API_KEY=your-stock-api-key
CRYPTO_MARKETS_API_KEY=your-crypto-api-key
ECONOMIC_INDICATORS_API_KEY=your-economic-api-key

# =============================================================================
# Pipeline Configuration
# =============================================================================

# Pipeline Settings
PIPELINE_MAX_PARALLEL_JOBS=10
PIPELINE_JOB_TIMEOUT_SECONDS=300
PIPELINE_BATCH_SIZE=100
PIPELINE_ENABLE_DEDUPLICATION=true
PIPELINE_ENABLE_EVIDENCE_EXTRACTION=true
PIPELINE_ENABLE_GRAPH_UPDATE=true
PIPELINE_CONFIDENCE_THRESHOLD=0.7

# Retry Settings
PIPELINE_RETRY_MAX_ATTEMPTS=3
PIPELINE_RETRY_BACKOFF_SECONDS=60
PIPELINE_MAX_BACKOFF_SECONDS=3600

# Cache Settings
PIPELINE_ENABLE_CACHING=true
PIPELINE_CACHE_TTL_SECONDS=3600

# Scheduler Settings
SCHEDULER_MAX_WORKERS=5
SCHEDULER_DEAD_LETTER_RETENTION_DAYS=30
SCHEDULER_MAX_FAILURES_BEFORE_DLQ=5

# Deduplication Settings
DEDUP_URL_ENABLED=true
DEDUP_CONTENT_ENABLED=true
DEDUP_SEMANTIC_ENABLED=true
DEDUP_TIME_WINDOW_ENABLED=true
DEDUP_SEMANTIC_THRESHOLD=0.85

# Storage Settings
STORAGE_TTL_HOURS=24
STORAGE_CLEANUP_INTERVAL_HOURS=6

# Metrics Settings
METRICS_ENABLED=true
METRICS_EXPORT_INTERVAL_SECONDS=60

# =============================================================================
# External Services - Government & Legal (Legacy)
# =============================================================================
GOVERNMENT_CONTRACTS_API_KEY=your-gov-contracts-api-key
PATENTS_API_KEY=your-patents-api-key
LEGAL_CASES_API_KEY=your-legal-api-key

# =============================================================================
# External Services - Academic & Research
# =============================================================================
ACADEMIC_SEARCH_API_KEY=your-academic-api-key
RESEARCH_PAPERS_API_KEY=your-research-api-key

# =============================================================================
# External Services - Social Media
# =============================================================================
TWITTER_API_KEY=your-twitter-api-key
TWITTER_API_SECRET=your-twitter-api-secret
LINKEDIN_API_KEY=your-linkedin-api-key
REDDIT_API_KEY=your-reddit-api-key

# =============================================================================
# External Services - Company Data
# =============================================================================
COMPANY_DATA_API_KEY=your-company-data-api-key
BUSINESS_REGISTRATIONS_API_KEY=your-registry-api-key
REVIEWS_API_KEY=your-reviews-api-key

# =============================================================================
# Payments - Stripe
# =============================================================================
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PRICE_ID_BASIC=price_basic_id
STRIPE_PRICE_ID_PRO=price_pro_id
STRIPE_PRICE_ID_ENTERPRISE=price_enterprise_id

# =============================================================================
# Email - SendGrid
# =============================================================================
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@atlas-platform.ai
SENDGRID_FROM_NAME=ATLAS Platform

# =============================================================================
# Verification Services
# =============================================================================
VERIFICATION_EMAIL_API_KEY=your-email-verification-key

# =============================================================================
# Communication Services
# =============================================================================
SMS_API_KEY=your-sms-api-key
SMS_ACCOUNT_ID=your-sms-account-id

# =============================================================================
# Translation
# =============================================================================
GOOGLE_TRANSLATE_API_KEY=your-translate-api-key
DEEPL_API_KEY=your-deepl-api-key

# =============================================================================
# Analytics
# =============================================================================
GOOGLE_ANALYTICS_TRACKING_ID=G-XXXXXXXXXX
DASHBOARDS_API_KEY=your-dashboards-api-key
CUSTOM_REPORTS_API_KEY=your-reports-api-key

# =============================================================================
# Cloud - AWS
# =============================================================================
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=atlas-platform
S3_BUCKET_REGION=us-east-1

# =============================================================================
# Cloud - GCP
# =============================================================================
GCP_ACCESS_KEY_ID=your-gcp-access-key
GCP_SECRET_ACCESS_KEY=your-gcp-secret-key

# =============================================================================
# Cloud - Azure
# =============================================================================
AZURE_ACCESS_KEY_ID=your-azure-access-key
AZURE_SECRET_ACCESS_KEY=your-azure-secret-key

# =============================================================================
# Logging & Monitoring
# =============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_OUTPUT=stdout

# Sentry
SENTRY_DSN=your-sentry-dsn
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=1.0

# Datadog
DATADOG_API_KEY=your-datadog-api-key
DATADOG_APP_KEY=your-datadog-app-key

# =============================================================================
# Feature Flags
# =============================================================================
ENABLE_NEW_INTELLIGENCE_ENGINE=true
ENABLE_ADVANCED_ANALYTICS=true
ENABLE_REAL_TIME_ALERTS=true

# =============================================================================
# Rate Limiting
# =============================================================================
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# =============================================================================
# Cache TTL (in seconds)
# =============================================================================
CACHE_TTL_SHORT=300       # 5 minutes
CACHE_TTL_MEDIUM=3600     # 1 hour
CACHE_TTL_LONG=86400      # 24 hours
CACHE_TTL_INTELLIGENCE=7200  # 2 hours
