# EditorConfig helps maintain consistent coding styles
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{yml,yaml}]
indent_size = 2

[*.{json,js,jsx,ts,tsx}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

[Dockerfile]
indent_size = 4

[*.py]
max_line_length = 100
indent_size = 4

[*.proto]
indent_size = 2

[*.sql]
indent_size = 4

[*.tf]
indent_size = 2

[.env*]
indent_size = 2
